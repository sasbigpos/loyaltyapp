# ─── LOYALCORE MEMBER — Firebase Environment Variables ───────────────────────
#
# 1. Copy this file to .env.local  (never commit .env.local to git)
# 2. Fill in the SAME values as apps/admin/.env.local
#    Both apps must point to the same Firebase project for live sync to work.
#
# See FIREBASE_SETUP.md for step-by-step instructions.

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Optional: GitHub Pages base path (defaults to /loyalcore/member/)
# VITE_BASE_URL=/loyalcore/member/
